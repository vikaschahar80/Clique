generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  password             String
  fullName             String
  role                 String                @default("user")
  isAdmin              Boolean               @default(false)
  createdAt            DateTime              @default(now())
  preferences          UserPreference?
  profile              UserProfile?
  verificationRequests VerificationRequest[]
  emailVerifications   EmailVerification[]
}

model UserProfile {
  id                         Int                 @id @default(autoincrement())
  userId                     Int                 @unique
  dob                        DateTime
  location                   String?
  city                       String?
  country                    String?
  latitude                   Float?
  longitude                  Float?
  photos                     String[]
  interests                  String[]
  aboutMe                    String?
  bio                        String?
  children                   String?
  college                    String?
  datingGoal                 RelationshipGoal?
  drinking                   LifestyleFrequency?
  drugs                      DrugFrequency?
  ethnicity                  String?
  exercise                   LifestyleFrequency?
  familyPlan                 String?
  height                     Int?
  hometown                   String?
  isCollegeVerified          Boolean             @default(false)
  isPersonVerified           Boolean             @default(false)
  isFaceVerified             Boolean             @default(false)
  isIdVerified               Boolean             @default(false)
  isWorkVerified             Boolean             @default(false)
  collegeEmail               String?
  workEmail                  String?
  isCollegeEmailVerified     Boolean             @default(false)
  isWorkEmailVerified        Boolean             @default(false)
  otherAffiliationEmail      String?
  isOtherAffiliationVerified Boolean             @default(false)
  language                   String[]
  pets                       String[]
  preferredName              String?
  prompt1Answer              String?
  prompt1Question            String?
  prompt2Answer              String?
  prompt2Question            String?
  prompt3Answer              String?
  prompt3Question            String?
  religion                   String?
  sexuality                  String?
  gender                     String?
  phoneNumber                String?
  smoking                    LifestyleFrequency?
  work                       String?
  user                       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationRequest {
  id                 String    @id @default(cuid())
  userId             Int
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName           String
  email              String
  selfieUrl          String
  idCardUrl          String?
  verificationMethod String    @default("id_document") // id_document | email
  affiliationEmail   String?
  status             String    @default("pending") // pending | approved | rejected
  resolvedAt         DateTime?
  resolvedByAdminId  Int?
  faceVerified       Boolean   @default(false)
  idVerified         Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId, status])
}

model EmailVerification {
  id         String    @id @default(cuid())
  userId     Int? // Nullable: null for pre-registration OTPs (no user yet)
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose    String // "registration" | "college" | "work" | "other"
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
}

model UserPreference {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  maxDistance        Int      @default(50)
  ageRangeMax        Int      @default(100)
  ageRangeMin        Int      @default(18)
  interestedInGender String[]
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum LifestyleFrequency {
  NEVER
  SOMETIMES
  OFTEN
  REGULARLY
  PREFER_NOT_TO_SAY
}

enum DrugFrequency {
  NEVER
  SOMETIMES
  OFTEN
  PREFER_NOT_TO_SAY
}

enum RelationshipGoal {
  LIFE_PARTNER
  LONG_TERM
  LONG_TERM_OPEN_TO_SHORT
  SHORT_TERM_OPEN_TO_LONG
  FIGURING_OUT
  FRIENDSHIP
  CASUAL
  PREFER_NOT_TO_SAY
}

