  THE_DORKIEST_THING_ABOUT_ME_IS
  I_WONT_SHUT_UP_ABOUT
  MY_GO_TO_KARAOKE_SONG_IS
  I_RECENTLY_DISCOVERED_THAT
  TOGETHER_WE_COULD
  IM_CONVINCED_THAT
